# Copy to env.email.local (same folder) — never commit env.email.local.
# Use the same MS Graph (or SMTP) values as your Vercel backend project.
#
# Microsoft Graph (preferred — same as signup OTP emails):
MS_GRAPH_TENANT_ID=
MS_GRAPH_CLIENT_ID=
MS_GRAPH_CLIENT_SECRET=
MS_GRAPH_MAILBOX=support@yourdomain.com
#
# Or SMTP fallback:
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=
