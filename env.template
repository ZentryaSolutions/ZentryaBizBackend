# Same DATABASE_URL in POS-Admin backend — one Supabase DB for both apps.
# Use Supabase Dashboard → Project → Connect → "Transaction pooler" (recommended for Vercel/serverless).
# Replace YOUR_DB_PASSWORD (URL-encode # as %23). Same value on Vercel → zentrya-biz-backend → DATABASE_URL.
# Supabase → Project Settings → Database → Database password (reset if unknown).

DATABASE_URL=postgresql://postgres.uginiwyezmlgawrexmnb:YOUR_DB_PASSWORD@aws-1-ap-northeast-1.pooler.supabase.com:6543/postgres

# Platform admin panel (separate domain) — first login creates admin if none exist
# PLATFORM_ADMIN_EMAIL=admin@yourdomain.com
# PLATFORM_ADMIN_PASSWORD=change-me-strong-password
# PLATFORM_ADMIN_NAME=Super Admin

PORT=5000
HOST=0.0.0.0

# Frontend URL in staff-invite / login-alert / billing emails (no trailing slash)
APP_BASE_URL=https://biz.zentryasolutions.com

# Login alert emails — local time zone (default Pakistan)
# APP_TIMEZONE=Asia/Karachi

# Google Sign-In — same Web client ID as REACT_APP_GOOGLE_CLIENT_ID on frontend
GOOGLE_OAUTH_CLIENT_ID=

# API session row in user_sessions expires after this many days (default 4; aligns with frontend stay-signed-in).
# SESSION_MAX_DAYS=4

ENABLE_MIGRATIONS=true
ENABLE_BACKUP_SCHEDULER=false

# Optional: set this in Vercel so /api/billing/send-renewal-reminders only accepts cron calls with this bearer token.
CRON_SECRET=

# License: default = validate against same DB as POS-Admin (licenses + activations). No POS-Admin API required.
# LICENSE_USE_REMOTE_LICENSE_VALIDATE=true
# LICENSE_SERVER_URL=https://api.zentryasolutions.com
