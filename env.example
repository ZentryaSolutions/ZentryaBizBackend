# Copy to .env or env.local — never commit real secrets.

# Postgres — HissabKitab-DB → Connect → Transaction pooler → URI (port 6543)
# URL-encode # in password as %23 (e.g. zentrya#123 → zentrya%23123)
DATABASE_URL=postgresql://postgres.uginiwyezmlgawrexmnb:YOUR_DB_PASSWORD@aws-1-ap-northeast-1.pooler.supabase.com:6543/postgres

# --- Microsoft Graph (OTP emails; preferred over SMTP when all set) ---
# Azure App Registration: client ID, tenant ID, client secret (rotate if exposed)
# Mail.Send application permission + admin consent
MS_GRAPH_TENANT_ID=
MS_GRAPH_CLIENT_ID=
MS_GRAPH_CLIENT_SECRET=
# Mailbox that sends (e.g. shared mailbox UPN)
MS_GRAPH_MAILBOX=support@yourdomain.com

# --- Fallback SMTP (if MS Graph env is incomplete) ---
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=

APP_NAME=Zentrya Biz

# Optional Vercel Cron protection for /api/billing/send-renewal-reminders
CRON_SECRET=

# Vercel sets VERCEL=1 at runtime — the API entry handles OPTIONS (CORS preflight) before Express.
# If you still see CORS errors, confirm the frontend uses REACT_APP_BACKEND_URL=https://<your-backend>.vercel.app (no trailing slash; /api is appended in code).
